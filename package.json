{
  "name": "@capire/bookshop",
  "version": "2.1.10",
  "description": "Our primer sample for getting started in a nutshell.",
  "repository": "https://github.com/capire/bookshop",
  "files": [
    "app",
    "srv",
    "db",
    "index.cds"
  ],
  "devDependencies": {
    "@cap-js/sqlite": "^2.1.1",
    "cds-plugin-ui5": "^0.13.0"
  },
  "dependencies": {
    "@sap/cds": "^9.6.2",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-project2": "cds watch --open project2/index.html?sap-ui-xx-viewCache=false --livereload false",
    "watch-com.scheer.book": "cds watch --open com.scheer.book/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "license": "Apache-2.0",
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/project1",
    "app/project2",
    "app/com.scheer.book"
  ],
  "cds": {
    "requires": {
      "businessPartner": {
        "kind": "odata-v2",
        "model": "srv/external/businessPartner"
      }
    }
  }
}

{
  "name": "@capire/bookshop",
  "version": "2.1.10",
  "description": "Our primer sample for getting started in a nutshell.",
  "repository": "https://github.com/capire/bookshop",
  "files": [
    "app",
    "srv",
    "db",
    "index.cds"
  ],
  "dependencies": {
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4",
    "@sap/cds": "^9.6.2"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@cap-js/sqlite": "^2.1.1",
    "jest": "^29.7.0",
    "prettier": "3.8.2"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "test": "jest --testPathPattern=test/"
  },
  "license": "Apache-2.0",
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/project1",
    "app/project2",
    "app/com.scheer.book",
    "app/com.scheer.order"
  ],
  "cds": {
    "requires": {
      "businessPartner": {
        "kind": "odata-v2",
        "model": "srv/external/businessPartner"
      },
      "db": {
        "[development]": {
          "credentials": {
            "url": "./db/data/db.sqlite"
          },
          "schema_evolution": "auto"
        },
        "[test]": {
          "credentials": {
            "url": ":memory:"
          }
        }
      }
    }
  }
}
